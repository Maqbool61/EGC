# =========================================================
# KEEP IMPORTANT FILES
# =========================================================
!package-lock.json
!yarn.lock
!pnpm-lock.yaml
!requirements.txt
!pyproject.toml
!README.md
!README.zh-CN.md
!LICENSE

# =========================================================
# KEEP CORE DOCUMENTATION
# =========================================================
!docs/
!docs/**/*.md

# =========================================================
# KEEP SOURCE CODE
# =========================================================
!src/
!src/**

# =========================================================
# KEEP TESTS
# =========================================================
!tests/
!tests/**

# =========================================================
# KEEP CONFIGURATION FILES
# =========================================================
!.gitignore
!.gitattributes
!.editorconfig
!.prettierrc
!.eslintrc*
!tsconfig.json

# =========================================================
# KEEP INSTALLERS / ENTRYPOINTS
# =========================================================
!install.sh
!run.sh
!startup.py

# =========================================================
# END
